# ============================================
# TradeStream Environment Configuration
# ============================================
# Copy to .env and fill in values before running docker compose.

# --- Application ---
APP_HTTP_PORT=8080
APP_GRPC_PORT=50051
APP_DEBUG_PORT=5005

# --- PostgreSQL ---
POSTGRES_DB=tradestream
POSTGRES_USER=tradestream
POSTGRES_PASSWORD=          # REQUIRED — set a strong password
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=changeme
REDIS_EXTERNAL_PORT=6379
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka (external) ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- InfluxDB (external) ---
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=tradestream
INFLUXDB_BUCKET=market_data

# --- API Keys ---
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
